<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalculatorCredit.WelcomePage"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <StyleSheet Source="/styles.css" />
    </ContentPage.Resources>

    <Grid BackgroundColor="#212429" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
        <Frame BackgroundColor="#282c34" CornerRadius="8" Margin="30" VerticalOptions="Center" Padding="25">
            <StackLayout Spacing="20">
                <!-- Заголовок -->
                <Label Text="Welcome" TextColor="#FFFFFF" StyleClass="welcome-title" HorizontalTextAlignment="Center" />

                <!-- Поля ввода -->
                <StackLayout Spacing="0">
                    <Entry x:Name="SurnameEntry" Placeholder="Username (Фамилия)" PlaceholderColor="#888888" StyleClass="login-entry" />
                    <BoxView HeightRequest="1" BackgroundColor="#CCCCCC" />
                    <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" PlaceholderColor="#888888" StyleClass="login-entry" />
                </StackLayout>

                <!-- Кнопка Sign in -->
                <Button x:Name="SignInButton" Text="Sign in" Clicked="SignInClicked" StyleClass="signin-button" />

                <!-- Нижняя часть с чекбоксом и ссылкой -->
                <Grid ColumnDefinitions="*, *">
                    <StackLayout Grid.Column="0" Orientation="Horizontal" Spacing="5">
                        <CheckBox x:Name="RememberCheckBox" Color="#FFFFFF" />
                        <Label Text="Remember me" TextColor="#FFFFFF" VerticalOptions="Center" FontSize="12" />
                    </StackLayout>
                    <Label Grid.Column="1" Text="I forgot!" TextColor="#888888" HorizontalOptions="End" VerticalOptions="Center" FontSize="12" />
                </Grid>
            </StackLayout>
        </Frame>
    </Grid>
</ContentPage>