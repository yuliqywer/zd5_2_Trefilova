<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalculatorCredit.RatesPage"
             Padding="20">
    <StackLayout Spacing="20">
        <StackLayout Spacing="5" Margin="0,0,0,0">
            <Label Text="Текущая дата:" TextDecorations="Underline" />
            <DatePicker x:Name="CurrencyDatePicker" Format="dd/MM/yyyy" />
        </StackLayout>

        <Label Text="Сбербанк:" />

        <StackLayout Spacing="10">
            <Label Text="USD   80.000" FontAttributes="Bold" FontSize="Medium" />
            <Label Text="EUR   86.000" FontAttributes="Bold" FontSize="Medium" />
        </StackLayout>
        <Button x:Name="StaticButton" 
                Text="Static (2 вариант)" 
                Clicked="OnStaticClicked"
                BackgroundColor="#e74c3c" 
                TextColor="#ffffff"
                FontSize="16"
                HeightRequest="50"
                Margin="0,20,0,0"/>
    </StackLayout>
</ContentPage>